# 12-factor config: copy to .env for local development. In CI/CD these are
# never read from a file -- each GitHub Environment (development/staging/
# production) injects its own values from GitHub Secrets into the job's
# environment (see .github/workflows/*.yml). Never commit a real .env file.

# --- shared by backend + ml -------------------------------------------------
ENVIRONMENT=development
MLFLOW_TRACKING_URI=./ml/mlruns
MLFLOW_MODEL_NAME=lol-win-predictor
# Staging deploys read the "Staging" candidate; production must only ever
# read "Production" (see final project spec, "Model Promotion Pipeline").
MLFLOW_MODEL_STAGE=Production

# Only needed if MLFLOW_TRACKING_URI points at a shared server (e.g. DagsHub)
# rather than a local ./mlruns folder:
# MLFLOW_TRACKING_USERNAME=
# MLFLOW_TRACKING_PASSWORD=

# --- backend -----------------------------------------------------------------
PORT=5000
CORS_ORIGINS=http://localhost:3000
GIT_COMMIT=local
APP_VERSION=0.1.0

# --- frontend ------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:5000
