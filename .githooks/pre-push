#!/usr/bin/env bash
# Runs ruff + the fast test suite before every `git push`. Kept in
# .githooks/ (not .git/hooks/) and wired up via
# `git config core.hooksPath .githooks` so it's version-controlled and every
# teammate gets it on clone (see scripts/setup-git-hooks.sh).
#
# The Selenium e2e test is excluded: it needs the frontend + backend running,
# which doesn't belong in a local pre-push hook. Runs in CI instead.
set -e

PYTHON=${PYTHON:-python}

echo "Running ruff..."
$PYTHON -m ruff check backend/app ml/src

echo "Running unit + integration tests..."
$PYTHON -m pytest tests/unit tests/integration

echo "All checks passed. Proceeding with push."
